@model JapaneseCarpartsStore.Models.Part

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name" />
        </div>
        <div class="col-md-6">
            <h1>@Model.Name</h1>
            <p class="lead">Brand: @Model.VehicleModel?.Brand?.Name</p>
            <h3 class="text-primary">@Model.Price.ToString("C")</h3>
            <p>@Model.Description</p>
            <div class="mt-4 mb-4">
                @* Sends the Part ID to the new CartController *@
                <form asp-controller="Cart" asp-action="Add" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm">
                        <i class="bi bi-cart-plus"></i> Add to Shopping Cart
                    </button>
                </form>
            </div>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card p-3 mb-4 shadow-sm bg-light">
            <h5>Leave a Review</h5>
            <form asp-action="LeaveReview" asp-route-id="@Model.Id" method="post">
                <div class="mb-3">
                    <label class="form-label">Rating</label>
                    <select name="rating" class="form-select">
                        <option value="5">5 - Excellent</option>
                        <option value="4">4 - Very Good</option>
                        <option value="3">3 - Good</option>
                        <option value="2">2 - Fair</option>
                        <option value="1">1 - Poor</option>
                    </select>
                </div>
                <div class="mb-3">
                    <textarea name="comment" class="form-control" rows="3" placeholder="Share your experience..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
        </div>
    }
    else
    {
        <p class="alert alert-secondary">Please <a asp-area="Identity" asp-page="/Account/Login">login</a> to leave a review.</p>
    }
    @* Call the partial here *@
    <partial name="_ReviewsPartial" model="Model.Reviews" />
</div>