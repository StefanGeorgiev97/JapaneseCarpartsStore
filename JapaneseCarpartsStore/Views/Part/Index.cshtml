@model JapaneseCarpartsStore.Core.ViewModels.AllPartsQueryModel

@{
    ViewBag.Title = "Japanese Car Parts Catalog";
}

<h2 class="text-center mb-4">@ViewBag.Title</h2>

<hr />

@* --- Search Bar --- *@
<form method="get">
    <div class="row justify-content-center mb-4">
        <div class="form-group col-md-8">
            <input asp-for="SearchTerm" class="form-control" placeholder="Search by name, description or brand...">
        </div>
        <div class="col-md-2">
            <input type="submit" value="Search" class="btn btn-primary w-100" />
        </div>
    </div>
</form>

@if (!Model.Parts.Any())
{
    <h3 class="text-center">No parts found by these criteria!</h3>
}

@* --- Parts Grid --- *@
<div class="row">
    @foreach (var part in Model.Parts)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                @if (!string.IsNullOrEmpty(part.ImageUrl))
                {
                    <img src="@part.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@part.Name">
                }
                else
                {
                    <img src="~/img/no-image.png" class="card-img-top" style="height: 200px; object-fit: cover;" alt="No image available">
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@part.Name</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@part.BrandName - @part.ModelName</h6>
                    <p class="card-text flex-grow-1 text-truncate" style="max-height: 50px;">@part.Description</p>
                    <div class="mt-auto">
                        <p class="h5 text-primary">@part.Price.ToString("C")</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* --- Pagination Controls --- *@
@{
    var previousPage = Model.CurrentPage - 1;
    if (previousPage < 1) previousPage = 1;

    var maxPage = Math.Ceiling((double)Model.TotalPartsCount / JapaneseCarpartsStore.Core.ViewModels.AllPartsQueryModel.PartsPerPage);
}

<div class="row mt-4">
    <div class="col-md-6">
        <a class="btn btn-secondary @(Model.CurrentPage == 1 ? "disabled" : string.Empty)"
           asp-controller="Part"
           asp-action="Index"
           asp-route-currentPage="@previousPage"
           asp-route-searchTerm="@Model.SearchTerm"><< Previous</a>
    </div>

    @{
        var shouldButtonBeDisabled = Model.CurrentPage == maxPage || !Model.Parts.Any();
    }

    <div class="col-md-6 text-end">
        <a class="btn btn-secondary @(shouldButtonBeDisabled ? "disabled" : string.Empty)"
           asp-controller="Part"
           asp-action="Index"
           asp-route-currentPage="@(Model.CurrentPage + 1)"
           asp-route-searchTerm="@Model.SearchTerm">Next >></a>
    </div>
</div>