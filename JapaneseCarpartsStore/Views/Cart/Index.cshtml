@model IEnumerable<JapaneseCarpartsStore.Models.Part>

<div class="container mt-5">
    <h2>Your Shopping Cart</h2>
    <hr />
    @if (!Model.Any())
    {
        <p>Your cart is empty. <a asp-controller="Part" asp-action="Index">Go shopping!</a></p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Part</th>
                    <th>Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
        <h4 class="text-end">Total: @Model.Sum(p => p.Price).ToString("C")</h4>
    }

    <form asp-controller="Order" asp-action="Complete" method="post" class="text-end">
        <button type="submit" class="btn btn-primary btn-lg mt-3">Finalize Purchase & Order</button>
    </form>
</div>