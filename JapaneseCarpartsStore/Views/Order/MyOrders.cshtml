@model IEnumerable<JapaneseCarpartsStore.Models.Order>

<div class="container mt-4">
    <h2 class="mb-4 text-center">My Order History</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't placed any orders yet. Visit our <a asp-controller="Part" asp-action="Index">catalog</a> to find performance parts!
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card mb-4 shadow-sm border-primary">
                <div class="card-header bg-dark text-white d-flex justify-content-between">
                    <span>Order #@order.Id</span>
                    <span>Date: @order.OrderDate.ToString("f")</span>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in order.OrderItems)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.Part.Name (@item.Part.VehicleModel?.Brand?.Name)
                                <span class="badge bg-secondary">@item.PriceAtPurchase.ToString("C")</span>
                            </li>
                        }
                    </ul>
                    <div class="text-end mt-3">
                        <h5>Total: <span class="text-success">@order.TotalPrice.ToString("C")</span></h5>
                    </div>
                </div>
            </div>
        }
    }
</div>